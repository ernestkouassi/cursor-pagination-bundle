{
    "name": "e2k/cursor-pagination-bundle",
    "description": "Symfony bundle for cursor-based (keyset) pagination with rich filter expression DSL",
    "type": "symfony-bundle",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "symfony/framework-bundle": "^5.4|^6.0|^7.0",
        "symfony/property-access": "^5.4|^6.0|^7.0",
        "doctrine/orm": "^2.14|^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0|^11.0",
        "symfony/phpunit-bridge": "^6.0|^7.0"
    },
    "autoload": {
        "psr-4": {
            "E2k\\CursorPaginationBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "E2k\\CursorPaginationBundle\\Tests\\": "tests/"
        }
    },
    "extra": {
        "symfony": {
            "allow-contrib": false
        }
    }
}
